# ═══════════════════════════════════════════════════════════
# LLM 预设 — 每个预设包含 API_KEY / BASE_URL / MODEL 三项
# 在 system.yaml 中设置 llm_preset 来选择使用哪个预设
# ═══════════════════════════════════════════════════════════

# ── openai ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── deepseek ───────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-6ce76b5e192b40508b6956c0b4b58b06
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── deepseek-reasoner ──────────────────────────────────────
DEEPSEEK_REASONER_API_KEY=sk-xxx
DEEPSEEK_REASONER_BASE_URL=https://api.deepseek.com
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── siliconflow ────────────────────────────────────────────
SILICONFLOW_API_KEY=sk-xxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# ── ollama ─────────────────────────────────────────────────
OLLAMA_API_KEY=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
